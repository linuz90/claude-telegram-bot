# Claude Telegram Bot - Environment Configuration

# ==============================================================================
# REQUIRED
# ==============================================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=replace_me

# Comma-separated Telegram user IDs allowed to use the bot
# Find your ID: message @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=123456789

# Main language selected during first setup.
# Supported values: en, tr
PRIMARY_LANGUAGE=en

# Optional comma-separated phrases that make the bot include recent audit-log
# context in the next prompt. This is for bot-control requests, not memory routing.
# RECENT_CONTEXT_KEYWORDS=last message,latest message,last conversation,transcript

# ==============================================================================
# RECOMMENDED
# ==============================================================================

# Working directory where Claude runs (loads CLAUDE.md, skills, MCP config)
CLAUDE_WORKING_DIR=/Users/yourname/personal

# OpenAI API key for voice message transcription
# Also enables /llm openai chat fallback
OPENAI_API_KEY=replace_me

# Default LLM provider: claude or openai
# Provider IDs come from built-ins plus optional llm-providers.ts.
# Claude is the full Claude Code agent. OpenAI-compatible providers can use native MCP tools.
# DEFAULT_LLM_PROVIDER=claude
# OPENAI_CHAT_MODEL=gpt-4.1-mini

# For OpenAI-compatible providers in llm-providers.ts:
# OPENROUTER_API_KEY=replace_me
# LOCAL_LLM_API_KEY=not-needed

# Optional local Whisper HTTP service for voice transcription.
# docker-compose.yml provides this as http://whisper:8000 for the bot container.
# WHISPER_SERVICE_URL=http://localhost:8087

# ==============================================================================
# OPTIONAL - Security
# ==============================================================================

# Comma-separated paths Claude can access
# Default: working dir, ~/Documents, ~/Downloads, ~/Desktop, ~/.claude
# Note: Setting this OVERRIDES defaults. Include ~/.claude for plan mode to work.
# ALLOWED_PATHS=/Users/yourname/personal,/Users/yourname/projects,/Users/yourname/.claude

# Rate limiting (token bucket)
# RATE_LIMIT_ENABLED=true
# RATE_LIMIT_REQUESTS=20
# RATE_LIMIT_WINDOW=60

# ==============================================================================
# OPTIONAL - Claude Authentication
# ==============================================================================

# API key for environments without Claude Code CLI auth
# Get from: https://console.anthropic.com/
# Note: API usage is billed per token - CLI auth is more cost-effective
# ANTHROPIC_API_KEY=replace_me

# Path to Claude CLI (auto-detected from PATH by default)
# CLAUDE_CLI_PATH=/usr/local/bin/claude

# MemPalace MCP URL. In Docker, use host.docker.internal to reach host service.
# MEMPALACE_MCP_URL=http://localhost:3100/mcp

# Docker-only: override container paths only if you also change docker-compose.yml mounts.
# Keep defaults for a clone-and-run setup.
# BOT_CONTAINER_WORKDIR=/app
# BOT_CONTAINER_ALLOWED_PATHS=/app,/home/bun/.claude,/home/bun/.codex,/home/bun/.gemini,/tmp/telegram-bot
# BOT_CONTAINER_WHISPER_SERVICE_URL=http://whisper:8000

# Docker-only: optional host auth mounts for CLI providers.
# Leave unset to use Docker named volumes, or set to host paths to reuse local auth.
# HOST_CLAUDE_DIR=~/.claude
# HOST_CLAUDE_JSON=~/.claude.json
# HOST_CODEX_DIR=~/.codex
# HOST_GEMINI_DIR=~/.gemini

# ==============================================================================
# OPTIONAL - Extended Thinking
# ==============================================================================

# Keywords that trigger extended thinking (comma-separated, case-insensitive)
# THINKING_KEYWORDS=think,pensa,ragiona

# Keywords that trigger deep thinking (50k tokens)
# THINKING_DEEP_KEYWORDS=ultrathink,think hard,pensa bene

# ==============================================================================
# OPTIONAL - Voice Transcription
# ==============================================================================

# Path to a text file with additional context for voice transcription
# (names, technical terms, etc. — keeps personal context outside this repo)
# TRANSCRIPTION_CONTEXT_FILE=/path/to/transcription-context.txt

# ==============================================================================
# OPTIONAL - Logging
# ==============================================================================

# Audit log path
# AUDIT_LOG_PATH=/tmp/claude-telegram-audit.log

# Output audit logs as JSON (default: human-readable)
# AUDIT_LOG_JSON=false
